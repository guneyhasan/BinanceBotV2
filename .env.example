# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=tradingbot
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tradingbot

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=tradingbot
RABBITMQ_PASSWORD=change_me_in_production

# Binance AL (Buy) Account
BINANCE_AL_API_KEY=your_al_api_key
BINANCE_AL_API_SECRET=your_al_api_secret

# Binance SAT (Sell) Account
BINANCE_SAT_API_KEY=your_sat_api_key
BINANCE_SAT_API_SECRET=your_sat_api_secret

# Binance Base URL (testnet or production)
BINANCE_BASE_URL=https://testnet.binancefuture.com

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_SIGNAL_CHAT_ID=your_signal_chat_id
TELEGRAM_TRADE_CHAT_ID=your_trade_chat_id

# Webhook Gateway
WEBHOOK_PORT=8080
WEBHOOK_SECRET=optional_shared_secret

# API Server
API_PORT=8081
